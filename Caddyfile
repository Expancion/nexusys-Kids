# Nexus Junior — Caddy reverse proxy
# tls internal = Caddy si vystaví vlastní lokální certifikát (HTTPS na portu 443)
# Pro důvěru certifikátu na klientech stáhni Caddy root CA:
#   docker compose exec caddy caddy trust
#   nebo stáhni /data/caddy/pki/authorities/local/root.crt

nexusys-kid.home.prod {
    tls internal
    reverse_proxy web:8080
}

# HTTP → HTTPS redirect
http://nexusys-kid.home.prod {
    redir https://{host}{uri} permanent
}
