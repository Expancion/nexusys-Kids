# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
KIOSK_ADMIN_PASSWORD=change-me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=homeapp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=homeapp
DATABASE_URL=postgresql+psycopg://homeapp:change-me@db:5432/homeapp

# ── YouTube Data API v3 (optional — needed for playlist import) ───────────────
# Get a free key at: https://console.cloud.google.com/
# Enable "YouTube Data API v3" → create an API key → paste it below.
YOUTUBE_API_KEY=

# ── Internal port (Caddy reverse-proxies this) ────────────────────────────────
APP_PORT=8080
